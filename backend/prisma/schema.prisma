model DeleteRequest {
  id          BigInt              @id @default(autoincrement()) @db.UnsignedBigInt
  targetType  String              @map("target_type") @db.VarChar(50)
  targetId    BigInt              @map("target_id") @db.UnsignedBigInt
  targetDesc  Json                @map("target_desc")
  requestedBy BigInt              @map("requested_by") @db.UnsignedBigInt
  requestTime DateTime            @default(now()) @map("request_time") @db.DateTime(0)
  status      DeleteRequestStatus @default(PENDING)
  reviewedBy  BigInt?             @map("reviewed_by") @db.UnsignedBigInt
  reviewedAt  DateTime?           @map("reviewed_at") @db.DateTime(0)
  reviewNote  String?             @map("review_note") @db.VarChar(500)

  requester User  @relation("DeleteRequestRequester", fields: [requestedBy], references: [id], onDelete: Restrict, onUpdate: Cascade)
  reviewer  User? @relation("DeleteRequestReviewer", fields: [reviewedBy], references: [id], onDelete: SetNull, onUpdate: Cascade)

  @@index([status])
  @@index([requestedBy])
  @@index([targetType, targetId])
  @@map("delete_requests")
}
