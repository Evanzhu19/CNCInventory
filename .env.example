# Public entrypoint for browser users.
# If you later put this behind HTTPS / reverse proxy, change it to your real domain.
APP_PUBLIC_URL=http://www.ruihongcnc.com

# Frontend is the only service exposed to the outside.
FRONTEND_BIND_ADDRESS=0.0.0.0
FRONTEND_PORT=80

# Optional debug tool. Adminer is disabled by default and only starts with:
# ./full-deploy.sh --with-adminer
ADMINER_BIND_ADDRESS=127.0.0.1
ADMINER_PORT=8080

TZ=America/New_York
BCRYPT_SALT_ROUNDS=10

# Database
MYSQL_DATABASE=tooling_inventory
MYSQL_USER=tooling_user
MYSQL_PASSWORD=change_this_mysql_app_password
MYSQL_ROOT_PASSWORD=change_this_mysql_root_password

# Backend auth
JWT_SECRET=change_this_to_a_long_random_secret_value

# Bootstrap admin account used by db-init seed
INITIAL_ADMIN_USERNAME=admin
INITIAL_ADMIN_PASSWORD=change_this_admin_password
INITIAL_ADMIN_REAL_NAME=系统管理员
